{
  "plugins": {
    "entries": {
      "supervisor": {
        "enabled": false,
        "config": {
          "gateEnabled": false,
          "gateEnvVar": "OPENCLAW_SUPERVISOR_ENABLED",
          "defaultFanout": "single",
          "highImportanceFanout": "multi",
          "maxRetriesPerWorker": 1,
          "verificationOnFlaggedCases": true,
          "maxVerificationWorkers": 1
        }
      }
    }
  }
}
